rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Helper: check if the request is from an authenticated user
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: validate image upload constraints
    function isValidImage() {
      return request.resource.contentType.matches('image/.*')
          && request.resource.size < 5 * 1024 * 1024; // 5 MB max
    }

    // Images uploaded via the admin / super-admin portals
    // Matches: images/branches/*, images/services/*, images/products/*, etc.
    match /images/{category}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && isValidImage();
      allow delete: if isAuthenticated();
    }

    // Business logos uploaded from settings page
    match /business-logos/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && isValidImage();
      allow delete: if isAuthenticated();
    }

    // CMS media (hero slides - images and videos)
    match /cms/{folder}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated()
                   && request.resource.size < 100 * 1024 * 1024;
      allow delete: if isAuthenticated();
    }

    // Chat attachments (messages pages)
    match /chat/{conversationId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidImage();
      allow delete: if isAuthenticated();
    }

    // Allow authenticated users to read/write any file under known prefixes
    // This catches any nested sub-paths that the single-segment wildcards miss
    match /{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
                   && request.resource.size < 5 * 1024 * 1024;
    }
  }
}
